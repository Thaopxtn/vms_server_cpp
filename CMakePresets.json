{
  "version": 3,
  "configurePresets": [
    {
      "name": "default-vcpkg",
      "displayName": "Default with vcpkg",
      "description": "Cấu hình CMake sử dụng bộ thư viện vcpkg toàn cục",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "D:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "vs2022-vcpkg",
      "displayName": "Visual Studio 2022 with vcpkg",
      "description": "Cấu hình CMake sử dụng Visual Studio 2022 Generator và vcpkg",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "D:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    }
  ]
}
